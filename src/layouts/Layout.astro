---
import '../styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import interWoff2Latin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import TopBar from '../components/TopBar.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import type { Lang } from '../i18n/translations';

interface Props {
    title: string;
    description?: string;
    lang?: Lang;
    alternateUrl?: string; // URL той же страницы на другом языке
    ogImage?: string;
}

const { title, description, lang = 'nl', alternateUrl, ogImage } = Astro.props;
const htmlLang = lang === 'en' ? 'en' : 'nl';
const siteUrl = 'https://ict-support-limburg.nl';
const nlPath = lang === 'nl' ? Astro.url.pathname : (alternateUrl ?? '/');
const enPath = lang === 'en' ? Astro.url.pathname : (alternateUrl ?? '/en/');
const nlUrl = `${siteUrl}${nlPath}`;
const enUrl = `${siteUrl}${enPath}`;
const canonicalUrl = lang === 'nl' ? nlUrl : enUrl;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/images/og-default.png`;
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
    <head>
        <!-- Google Tag Manager -->
        <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-5S8ZWBWH');</script>
        <!-- End Google Tag Manager -->
        <!-- Microsoft Clarity -->
        <script type="text/javascript" is:inline>
            (function(c,l,a,r,i,t,y){
                c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
            })(window, document, "clarity", "script", "wbyiwuk5ul");
        </script>
        <!-- End Microsoft Clarity -->
        <meta charset="UTF-8" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <meta name="apple-mobile-web-app-title" content="IT Support" />
        <link rel="manifest" href="/site.webmanifest" />
        <link rel="preload" as="font" type="font/woff2" href={interWoff2Latin} crossorigin />
        <link rel="alternate" hreflang="nl" href={nlUrl} />
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="x-default" href={nlUrl} />
        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:site_name" content="Oros IT Support Limburg" />
        <meta property="og:locale" content={lang === 'en' ? 'en_GB' : 'nl_NL'} />
        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl} />
        <slot name="head" />
    </head>
    <body class="font-sans antialiased">
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5S8ZWBWH"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
        <TopBar lang={lang} />
        <SiteHeader lang={lang} nlUrl={nlUrl} enUrl={enUrl} />
        <main>
            <slot />
        </main>
        <SiteFooter lang={lang} />

        <script>
            const revealObserver = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('revealed');
                            revealObserver.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.08 }
            );
            document.querySelectorAll('.scroll-reveal').forEach((el) => revealObserver.observe(el));
        </script>
        <script>
            import '../scripts/form-handler.ts';
        </script>
    </body>
</html>
