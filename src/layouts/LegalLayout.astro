---
import Layout from './Layout.astro';
import type { Lang } from '../i18n/translations';

interface Props {
    title: string;
    description: string;
    lang?: Lang;
    alternateUrl?: string;
    lastUpdated?: string;
}

const { title, description, lang = 'nl', alternateUrl, lastUpdated } = Astro.props;
const updatedLabel = lang === 'en' ? 'Last updated' : 'Laatste update';
---

<Layout title={title} description={description} lang={lang} alternateUrl={alternateUrl}>
    <section class="bg-white section-padding">
        <div class="container-main max-w-3xl">
            {lastUpdated && (
                <p class="mb-6 text-xs text-muted-foreground">{updatedLabel}: {lastUpdated}</p>
            )}
            <div class="legal-content">
                <slot />
            </div>
        </div>
    </section>
</Layout>

<style>
    .legal-content :global(h1) {
        font-size: clamp(1.75rem, 5vw, 2.5rem);
        font-weight: 700;
        color: var(--color-primary);
        line-height: 1.2;
        margin-bottom: 1.5rem;
    }

    .legal-content :global(h2) {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-primary);
        line-height: 1.3;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
    }

    .legal-content :global(h3) {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-primary);
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .legal-content :global(p) {
        color: var(--color-muted-foreground);
        line-height: 1.75;
        margin-bottom: 1rem;
    }

    .legal-content :global(ul),
    .legal-content :global(ol) {
        margin: 0.75rem 0 1rem 1.5rem;
        color: var(--color-muted-foreground);
        line-height: 1.75;
    }

    .legal-content :global(ul) {
        list-style-type: disc;
    }

    .legal-content :global(ol) {
        list-style-type: decimal;
    }

    .legal-content :global(li) {
        margin-bottom: 0.35rem;
    }

    .legal-content :global(a) {
        color: var(--color-accent);
        text-decoration: none;
    }

    .legal-content :global(a:hover) {
        text-decoration: underline;
    }

    .legal-content :global(strong) {
        color: var(--color-primary);
        font-weight: 600;
    }

    .legal-content :global(hr) {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2rem 0;
    }

    .legal-content :global(table) {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        margin: 1rem 0 1.5rem;
        overflow-x: auto;
        display: block;
    }

    .legal-content :global(th) {
        text-align: left;
        padding: 0.6rem 0.75rem;
        font-weight: 600;
        color: var(--color-primary);
        border-bottom: 2px solid var(--color-border);
        background: var(--color-muted);
        white-space: nowrap;
    }

    .legal-content :global(td) {
        padding: 0.6rem 0.75rem;
        color: var(--color-muted-foreground);
        border-bottom: 1px solid var(--color-border);
        vertical-align: top;
    }

    .legal-content :global(tr:last-child td) {
        border-bottom: none;
    }

    .legal-content :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        padding-left: 1rem;
        margin: 1rem 0;
        color: var(--color-muted-foreground);
        font-style: italic;
    }
</style>
