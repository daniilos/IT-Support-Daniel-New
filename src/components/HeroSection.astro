---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'nl' } = Astro.props;
const t = translations[lang].hero;
---

<section class="bg-white section-padding !pb-10 md:!pb-14">
    <div class="container-main">
        <div class="mx-auto max-w-3xl text-center">
            <h1 class="mb-6">
                {t.heading}<br />
                <span class="text-accent">{t.headingAccent}</span>
            </h1>
            <p class="mx-auto mb-4 max-w-2xl text-lg text-muted-foreground">
                {t.subtitle}
            </p>
            <p class="mx-auto mb-8 max-w-xl text-base font-medium text-foreground">
                {t.valueProps}
            </p>
            <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
                <a href="#contact" class="btn-primary px-8 py-3.5 text-base">{t.cta1}</a>
                <a href="#contact" class="btn-outline px-8 py-3.5 text-base">{t.cta2}</a>
            </div>
        </div>
    </div>
</section>
