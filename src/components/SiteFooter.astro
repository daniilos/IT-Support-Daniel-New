---
import { translations, type Lang } from '../i18n/translations';
import { ObfuscatedLink, ObfuscatedText } from './ObfuscatedContact';
interface Props { lang?: Lang }
const { lang = 'nl' } = Astro.props;
const t = translations[lang].footer;
---

<footer class="border-t border-border bg-primary text-white">
    <div class="container-main section-padding !py-12">
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5">
            <div class="lg:col-span-2">
                <a href={lang === 'en' ? '/en/' : '/'} class="mb-4 inline-flex items-center gap-2.5 no-underline transition-opacity hover:opacity-80">
                    <img src="/images/oit-logo.svg" alt="Oros IT Support" class="h-10 w-auto sm:h-11" style="filter: brightness(0) invert(1);" />
                    <span class="flex flex-col leading-none">
                        <span class="text-sm font-bold tracking-wide text-white sm:text-[0.9375rem]">{lang === 'en' ? 'IT Support' : 'ICT Support'}</span>
                        <span class="text-xs font-semibold tracking-wider text-white/60 sm:text-sm">Limburg</span>
                    </span>
                </a>
                <p class="mt-3 max-w-sm text-sm leading-relaxed text-white/75">
                    {t.description}
                </p>
                <div class="mt-4 flex flex-col gap-1 text-sm text-white/75">
                    <span>{t.companyName}</span>
                    <ObfuscatedText client:load encoded="S2lldml0c3RyYWF0IDI1" />
                    <ObfuscatedText client:load encoded="NjQ2OSBYWCBLZXJrcmFkZQ==" />
                    <ObfuscatedLink
                        client:load
                        encoded="dGVsOiszMTYzNDgzNjExOA=="
                        label="KzMxIDYgMzQ4MyA2MTE4"
                        className="mt-1 text-white/85 no-underline hover:text-white transition-colors"
                    />
                    <ObfuscatedLink
                        client:load
                        encoded="bWFpbHRvOmRhbmllbEBpY3Qtc3VwcG9ydC1saW1idXJnLm5s"
                        label="ZGFuaWVsQGljdC1zdXBwb3J0LWxpbWJ1cmcubmw="
                        className="text-white/85 no-underline hover:text-white transition-colors"
                    />
                </div>
                <div class="mt-4 space-y-1 text-sm text-white/70">
                    <p>{t.kvkLabel}: {t.kvkValue}</p>
                    <p>{t.vatLabel}: {t.vatValue}</p>
                </div>
            </div>

            <div>
                <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-white/60">{t.servicesTitle}</p>
                <ul class="flex flex-col gap-1">
                    {t.servicesLinks.map((label) => (
                        <li>
                            <a href="#services" class="inline-block py-1 text-sm text-white/75 no-underline transition-colors hover:text-white">
                                {label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <div>
                <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-white/60">{t.linksTitle}</p>
                <ul class="flex flex-col gap-1">
                    {t.navLinks.map((link) => (
                        <li>
                            <a href={link.href} class="inline-block py-1 text-sm text-white/75 no-underline transition-colors hover:text-white">
                                {link.label}
                            </a>
                        </li>
                    ))}
                    <li>
                        <button
                            type="button"
                            class="inline-block py-1 text-left text-sm text-white/75 no-underline transition-colors hover:text-white cursor-pointer"
                            data-cookie-open-settings
                        >
                            {t.cookieSettings}
                        </button>
                    </li>
                </ul>
            </div>

            <div>
                <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-white/60">{t.legalTitle}</p>
                <ul class="flex flex-col gap-1">
                    {t.legalLinks.map((link) => (
                        <li>
                            <a href={link.href} class="inline-block py-1 text-sm text-white/75 no-underline transition-colors hover:text-white">
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>
        </div>

        <div class="mt-10 border-t border-white/15 pt-6 text-center">
            <p class="text-sm text-white/60">
                &copy; 2025{new Date().getFullYear() > 2025 ? `–${new Date().getFullYear()}` : ''} {t.copyright}
            </p>
        </div>
    </div>
</footer>
