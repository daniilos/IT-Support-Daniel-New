---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'nl' } = Astro.props;
const t = translations[lang].about;
---

<section id="about" class="section-padding bg-section-alt">
    <div class="container-main">
        <div class="mx-auto max-w-3xl">
            <h2 class="mb-8 text-center">{t.heading}</h2>

            <div class="space-y-4 text-muted-foreground">
                {t.paragraphs.map((p) => (
                    <p class="text-base leading-relaxed">{p}</p>
                ))}
            </div>

            <div class="mt-6">
                <p class="font-semibold text-primary">{t.approach}</p>
                <p class="text-base text-foreground">{t.approachText}</p>
            </div>

            <blockquote class="mt-10 border-l-4 border-accent pl-6">
                <p class="text-lg italic text-primary leading-relaxed">{t.quote}</p>
                <footer class="mt-3 text-sm font-semibold text-muted-foreground">{t.quoteAuthor}</footer>
            </blockquote>
        </div>
    </div>
</section>
