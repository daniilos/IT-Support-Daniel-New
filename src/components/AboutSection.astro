---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'nl' } = Astro.props;
const t = translations[lang].about;
---

<section id="about" class="section-padding bg-section-alt">
    <div class="container-main">
        <h2 class="mb-10 text-center">{t.heading}</h2>

        <div class="mx-auto max-w-5xl">
            <div class="grid items-start gap-10 md:grid-cols-5">
                <div class="flex justify-center md:col-span-2">
                    <div class="relative">
                        <div class="absolute -inset-3 -z-10 rounded-3xl bg-gradient-to-br from-blue-50 to-slate-100"></div>
                        <img
                            src="/images/daniel2_1.png"
                            alt="Daniel Oros"
                            width="597"
                            height="800"
                            class="h-auto w-full max-w-[280px] rounded-2xl object-cover md:max-w-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>

                <div class="md:col-span-3">
                    <div class="space-y-4 text-muted-foreground">
                        {t.paragraphs.map((p) => (
                            <p class="text-base leading-relaxed">{p}</p>
                        ))}
                    </div>

                    <div class="mt-6">
                        <p class="font-semibold text-primary">{t.approach}</p>
                        <p class="text-base text-foreground">{t.approachText}</p>
                    </div>

                    <blockquote class="mt-8 border-l-4 border-accent pl-6">
                        <p class="text-lg italic text-primary leading-relaxed">{t.quote}</p>
                        <footer class="mt-3 text-sm font-semibold text-muted-foreground">{t.quoteAuthor}</footer>
                    </blockquote>
                </div>
            </div>
        </div>
    </div>
</section>
