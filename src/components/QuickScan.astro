---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'nl' } = Astro.props;
const t = translations[lang].quickScan;
---

<section class="section-padding bg-section-alt">
    <div class="container-main">
        <div class="mx-auto max-w-3xl rounded-2xl border border-border bg-white p-8 md:p-10">
            <h2 class="mb-4 text-center">{t.heading}</h2>
            <p class="mb-6 text-center text-lg text-muted-foreground">{t.intro}</p>

            <p class="mb-4 font-semibold text-primary">{t.checkIntro}</p>
            <ul class="mb-6 grid gap-2 sm:grid-cols-2">
                {t.checks.map((check) => (
                    <li class="flex items-center gap-3 text-sm text-foreground">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                        <span>{check}</span>
                    </li>
                ))}
            </ul>

            <p class="mb-8 text-sm text-muted-foreground">{t.result}</p>

            <div class="text-center">
                <a href="#contact" class="btn-primary px-8 py-3.5 text-base">{t.cta}</a>
            </div>
        </div>
    </div>
</section>
