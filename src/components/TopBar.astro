---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'nl' } = Astro.props;
const t = translations[lang].topBar;
---

<div class="bg-primary text-white">
    <div class="container-main flex flex-wrap items-center justify-between gap-2 px-4 py-2 text-sm sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center gap-4 sm:gap-6">
            <a href="tel:+31634836118" class="no-underline text-white/90 transition-colors hover:text-white">
                {t.phone}
            </a>
            <a href="mailto:info@oros.agency" class="no-underline text-white/90 transition-colors hover:text-white">
                {t.email}
            </a>
        </div>
        <div class="text-white/80 text-xs sm:text-sm">{t.hours}</div>
    </div>
</div>
