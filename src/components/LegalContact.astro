---
/**
 * Renders obfuscated email and phone links for use inside legal (Markdown) pages.
 * Values are stored as base64 in data-attributes and decoded client-side only.
 * Static HTML never contains raw email or phone text.
 *
 * Props:
 *   type: 'email' | 'phone'
 *   className: optional extra CSS classes
 */
interface Props {
    type: 'email' | 'phone';
    class?: string;
}
const { type, class: className } = Astro.props;

// base64-encoded values — never rendered as plain text in server HTML
const EMAIL_HREF  = 'bWFpbHRvOmRhbmllbEBpY3Qtc3VwcG9ydC1saW1idXJnLm5s';
const EMAIL_LABEL = 'ZGFuaWVsQGljdC1zdXBwb3J0LWxpbWJ1cmcubmw=';
const PHONE_HREF  = 'dGVsOiszMTYzNDgzNjExOA==';
const PHONE_LABEL = 'KzMxIDYgMzQ4MyA2MTE4';

const id   = `lc-${type}-${Math.random().toString(36).slice(2, 7)}`;
const href = type === 'email' ? EMAIL_HREF : PHONE_HREF;
const lbl  = type === 'email' ? EMAIL_LABEL : PHONE_LABEL;
---

<span id={id} class={className}></span>
<script is:inline define:vars={{ id, href, lbl }}>
(function () {
    var el = document.getElementById(id);
    if (!el) return;
    try {
        var h = atob(href);
        var t = atob(lbl);
        var a = document.createElement('a');
        a.href = h;
        a.textContent = t;
        el.replaceWith(a);
    } catch (_) {}
})();
</script>
