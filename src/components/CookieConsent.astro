---
import { translations, type Lang } from '../i18n/translations';

interface Props {
    lang?: Lang;
}

const { lang = 'nl' } = Astro.props;
const t = translations[lang].cookieConsent;
---

<div
    id="cookie-consent"
    data-cookie-banner
    hidden
    class="fixed inset-x-0 bottom-0 z-[70] p-4 sm:p-6"
    role="dialog"
    aria-modal="false"
    aria-labelledby="cookie-consent-title"
    aria-describedby="cookie-consent-description"
>
    <div class="mx-auto max-w-5xl rounded-3xl border border-border bg-white/98 shadow-2xl backdrop-blur">
        <div class="flex flex-col gap-6 p-6 sm:p-8">
            <div class="flex flex-col gap-2">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">{t.badge}</p>
                <p id="cookie-consent-title" class="text-xl font-bold leading-tight text-primary sm:text-2xl">
                    {t.title}
                </p>
                <p id="cookie-consent-description" class="max-w-3xl text-sm text-muted-foreground sm:text-base">
                    {t.description}
                </p>
            </div>

            <form data-cookie-consent-form class="contents">
                <div class="space-y-4">
                    <label class="flex items-start gap-4 rounded-2xl border border-border bg-muted p-5">
                        <input
                            type="checkbox"
                            checked
                            disabled
                            aria-disabled="true"
                            class="mt-1 h-5 w-5 rounded border-border text-accent accent-accent disabled:opacity-100"
                        />
                        <span class="min-w-0">
                            <span class="block text-sm font-semibold text-primary">{t.baseAnalyticsTitle}</span>
                            <span class="mt-1 block text-sm text-muted-foreground">{t.baseAnalyticsDescription}</span>
                        </span>
                    </label>

                    <label class="flex items-start gap-4 rounded-2xl border border-accent/20 bg-blue-50 p-5">
                        <input
                            type="checkbox"
                            checked
                            data-consent-analytics-checkbox
                            aria-label={t.optionalToggleLabel}
                            class="mt-1 h-5 w-5 rounded border-border text-accent accent-accent"
                        />
                        <span class="min-w-0">
                            <span class="block text-sm font-semibold text-primary">{t.optionalTitle}</span>
                            <span class="mt-1 block text-sm text-muted-foreground">{t.optionalDescription}</span>
                        </span>
                    </label>
                </div>

                <div class="flex flex-col gap-4 border-t border-border pt-5 sm:flex-row sm:items-center sm:justify-between">
                    <p class="max-w-2xl text-xs text-muted-foreground sm:text-sm">
                        {t.policyNote}
                    </p>

                    <div class="w-full sm:w-auto">
                        <button
                            type="submit"
                            data-cookie-save
                            class="btn-primary w-full !min-h-12 !px-8 !py-3 !text-base sm:min-w-56"
                        >
                            {t.saveLabel}
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
