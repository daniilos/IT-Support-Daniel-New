---
import { translations, type Lang } from '../i18n/translations';

interface Props {
    lang?: Lang;
}

const { lang = 'nl' } = Astro.props;
const t = translations[lang].cookieConsent;
---

<div
    id="cookie-consent"
    data-cookie-banner
    hidden
    class="fixed inset-x-0 bottom-0 z-[70] p-4 sm:p-6"
    role="dialog"
    aria-modal="false"
    aria-labelledby="cookie-consent-title"
    aria-describedby="cookie-consent-description"
>
    <div class="mx-auto max-w-5xl rounded-3xl border border-border bg-white/98 shadow-2xl backdrop-blur max-sm:max-h-[30dvh] max-sm:overflow-y-auto">
        <div class="flex flex-col gap-6 p-6 sm:p-8">
            <div class="flex flex-col gap-2">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">{t.badge}</p>
                <p id="cookie-consent-title" class="text-xl font-bold leading-tight text-primary sm:text-2xl">
                    {t.title}
                </p>
                <p id="cookie-consent-description" class="max-w-3xl text-sm text-muted-foreground sm:text-base">
                    {t.description}
                </p>
            </div>

            <form data-cookie-consent-form class="contents">
                <div class="space-y-4">
                    <div class="rounded-2xl border border-border bg-muted p-5">
                        <div class="flex items-start gap-4">
                            <span
                                aria-hidden="true"
                                class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded border border-accent bg-accent text-white"
                            >
                                <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M3.5 8.25 6.5 11l6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                                </svg>
                            </span>
                            <span class="min-w-0 flex-1">
                                <span class="flex flex-wrap items-center gap-2">
                                    <span class="text-sm font-semibold text-primary">{t.baseAnalyticsToggleLabel}</span>
                                    <span class="inline-flex items-center rounded-full bg-accent px-2.5 py-0.5 text-[11px] font-semibold text-white">
                                        {t.alwaysOnLabel}
                                    </span>
                                </span>
                                <span class="mt-1 block text-sm text-muted-foreground">{t.baseAnalyticsDescription}</span>
                            </span>
                        </div>
                    </div>

                    <label class="flex items-start gap-4 rounded-2xl border border-accent/20 bg-blue-50 p-5">
                        <input
                            type="checkbox"
                            checked
                            data-consent-analytics-checkbox
                            aria-label={t.clarityToggleLabel}
                            class="mt-0.5 h-5 w-5 flex-shrink-0 rounded border-border text-accent accent-accent"
                        />
                        <span class="min-w-0 flex-1">
                            <span class="block text-sm font-semibold text-primary">{t.clarityToggleShortLabel}</span>
                            <span class="mt-1 block text-sm text-muted-foreground">{t.optionalDescription}</span>
                        </span>
                    </label>
                </div>

                <div class="flex flex-col gap-4 border-t border-border pt-5 sm:flex-row sm:items-center sm:justify-between">
                    <p class="max-w-2xl text-xs text-muted-foreground sm:text-sm">
                        {t.policyNote}
                    </p>

                    <div class="w-full sm:w-auto">
                        <button
                            type="submit"
                            data-cookie-save
                            class="btn-primary w-full !min-h-12 !px-8 !py-3 !text-base sm:min-w-56"
                        >
                            {t.saveLabel}
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

{/* Collapsed cookie chip — shown on mobile after auto-hide */}
<button
    id="cookie-chip"
    hidden
    aria-label={t.badge}
    class="fixed bottom-4 left-4 z-[70] flex items-center gap-2 rounded-full border border-border bg-white/95 px-3.5 py-2 text-xs font-semibold text-primary shadow-lg backdrop-blur transition-all active:scale-95 sm:hidden"
>
    <svg class="h-3.5 w-3.5 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
    </svg>
    {t.badge}
</button>

<script>
(function () {
    const MOBILE_BREAKPOINT = 640; // same as Tailwind sm:
    const AUTO_HIDE_MS = 5000;

    function isMobile() {
        return window.innerWidth < MOBILE_BREAKPOINT;
    }

    function collapseToChip() {
        const banner = document.getElementById('cookie-consent');
        const chip   = document.getElementById('cookie-chip');
        if (!banner || !chip) return;

        // animate banner out
        banner.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
        banner.style.opacity    = '0';
        banner.style.transform  = 'translateY(12px)';

        setTimeout(() => {
            banner.hidden = true;
            banner.removeAttribute('style');
            chip.hidden = false;
        }, 300);
    }

    function expandFromChip() {
        const banner = document.getElementById('cookie-consent');
        const chip   = document.getElementById('cookie-chip');
        if (!banner || !chip) return;

        chip.hidden = true;
        banner.hidden = false;
        banner.style.opacity   = '0';
        banner.style.transform = 'translateY(12px)';
        banner.style.transition = 'opacity 0.3s ease, transform 0.3s ease';

        // force reflow then animate in
        void banner.offsetHeight;
        banner.style.opacity   = '1';
        banner.style.transform = 'translateY(0)';

        setTimeout(() => {
            banner.removeAttribute('style');
        }, 300);
    }

    function maybeScheduleAutoHide() {
        if (!isMobile()) return;

        const banner = document.getElementById('cookie-consent');
        if (!banner || banner.hidden) return;

        setTimeout(() => {
            // only collapse if banner is still visible (user hasn't saved yet)
            const b = document.getElementById('cookie-consent');
            if (b && !b.hidden) {
                collapseToChip();
            }
        }, AUTO_HIDE_MS);
    }

    function init() {
        const chip = document.getElementById('cookie-chip');
        if (chip) {
            chip.addEventListener('click', expandFromChip);
        }

        // Watch for the banner becoming visible (cookie-consent.ts sets hidden=false)
        const banner = document.getElementById('cookie-consent');
        if (!banner) return;

        const observer = new MutationObserver(() => {
            if (!banner.hidden) {
                maybeScheduleAutoHide();
            }
        });

        observer.observe(banner, { attributes: true, attributeFilter: ['hidden'] });

        // Also run immediately in case banner is already visible on load
        if (!banner.hidden) {
            maybeScheduleAutoHide();
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
</script>
