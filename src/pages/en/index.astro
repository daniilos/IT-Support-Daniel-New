---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';
import HeroSection from '../../components/HeroSection.astro';
import TrustBar from '../../components/TrustBar.astro';
import ServicesGrid from '../../components/ServicesGrid';
import AboutSection from '../../components/AboutSection.astro';
import WhyOros from '../../components/WhyOros.astro';
import CommonProblems from '../../components/CommonProblems.astro';
import ComparisonSection from '../../components/ComparisonSection.astro';
import QuickScan from '../../components/QuickScan.astro';
import PricingSection from '../../components/PricingSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import BlogPreview from '../../components/BlogPreview.astro';
import ContactForm from '../../components/ContactForm';

const lang = 'en';
const t = translations[lang];

const localBusinessSchema = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Oros IT Support",
    "description": "IT support in Zuid-Limburg for small businesses. Computers, printers, Wi-Fi, Microsoft 365, repairs and security — fast, local and straightforward.",
    "url": "https://ict-support-limburg.nl/en/",
    "telephone": "+31634836118",
    "email": "info@oros.agency",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "Kievitstraat 25",
        "addressLocality": "Kerkrade",
        "addressRegion": "Limburg",
        "postalCode": "6469 XX",
        "addressCountry": "NL"
    },
    "geo": {
        "@type": "GeoCoordinates",
        "latitude": 50.8653,
        "longitude": 6.0613
    },
    "openingHoursSpecification": [
        {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "09:00",
            "closes": "18:00"
        }
    ],
    "priceRange": "€€",
    "areaServed": [
        { "@type": "City", "name": "Kerkrade" },
        { "@type": "City", "name": "Heerlen" },
        { "@type": "City", "name": "Maastricht" },
        { "@type": "City", "name": "Sittard" },
        { "@type": "City", "name": "Brunssum" }
    ],
    "founder": {
        "@type": "Person",
        "name": "Daniel Orosz"
    }
};

const websiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Oros IT Support",
    "url": "https://ict-support-limburg.nl/en/",
    "description": "IT support in Zuid-Limburg for small businesses",
    "inLanguage": "en-GB",
    "publisher": {
        "@type": "LocalBusiness",
        "name": "Oros IT Support"
    }
};
---

<Layout title={t.meta.title} description={t.meta.description} lang={lang} alternateUrl="/">
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    </Fragment>
    <HeroSection lang={lang} />
    <TrustBar lang={lang} />
    <div class="scroll-reveal">
        <ServicesGrid lang={lang} />
    </div>
    <div class="scroll-reveal">
        <AboutSection lang={lang} />
    </div>
    <div class="scroll-reveal">
        <WhyOros lang={lang} />
    </div>
    <div class="scroll-reveal">
        <CommonProblems lang={lang} />
    </div>
    <div class="scroll-reveal">
        <ComparisonSection lang={lang} />
    </div>
    <div class="scroll-reveal">
        <QuickScan lang={lang} />
    </div>
    <div class="scroll-reveal">
        <PricingSection lang={lang} />
    </div>
    <div class="scroll-reveal">
        <FaqSection lang={lang} />
    </div>
    <div class="scroll-reveal">
        <BlogPreview lang={lang} />
    </div>
    <div class="scroll-reveal">
        <ContactForm lang={lang} />
    </div>
</Layout>
