---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';
import HeroSection from '../../components/HeroSection.astro';
import TrustBar from '../../components/TrustBar.astro';
import ServicesGrid from '../../components/ServicesGrid';
import AboutSection from '../../components/AboutSection.astro';
import WhyOros from '../../components/WhyOros.astro';
import CommonProblems from '../../components/CommonProblems.astro';
import ComparisonSection from '../../components/ComparisonSection.astro';
import QuickScan from '../../components/QuickScan.astro';
import PricingSection from '../../components/PricingSection.astro';
import ContactForm from '../../components/ContactForm';

const lang = 'en';
const t = translations[lang].meta;
---

<Layout title={t.title} description={t.description} lang={lang}>
    <HeroSection lang={lang} />
    <TrustBar lang={lang} />
    <div class="scroll-reveal">
        <ServicesGrid lang={lang} />
    </div>
    <div class="scroll-reveal">
        <AboutSection lang={lang} />
    </div>
    <div class="scroll-reveal">
        <WhyOros lang={lang} />
    </div>
    <div class="scroll-reveal">
        <CommonProblems lang={lang} />
    </div>
    <div class="scroll-reveal">
        <ComparisonSection lang={lang} />
    </div>
    <div class="scroll-reveal">
        <QuickScan lang={lang} />
    </div>
    <div class="scroll-reveal">
        <PricingSection lang={lang} />
    </div>
    <div class="scroll-reveal">
        <ContactForm lang={lang} />
    </div>
</Layout>
