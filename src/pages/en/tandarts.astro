---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm';

const lang = 'en';
const slug = 'en/tandarts';
const siteUrl = 'https://ict-support-limburg.nl';

const title = 'IT support for dental practices in Limburg | Oros IT Support';
const description = 'IT support for dental practices in Zuid-Limburg. Exquise, X-ray systems, workstations and internal processes: fast, local, no fuss. 7 years working daily inside dental organisations.';

const localBusinessSchema = {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "MedicalBusiness"],
    "name": "Oros IT Support Limburg",
    "description": description,
    "url": `${siteUrl}/${slug}/`,
    "telephone": "+31634836118",
    "email": "daniel@ict-support-limburg.nl",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "Kievitstraat 25",
        "addressLocality": "Kerkrade",
        "addressRegion": "Limburg",
        "postalCode": "6469 XX",
        "addressCountry": "NL"
    },
    "areaServed": [
        { "@type": "City", "name": "Kerkrade" },
        { "@type": "City", "name": "Heerlen" },
        { "@type": "City", "name": "Maastricht" },
        { "@type": "City", "name": "Sittard" }
    ],
    "knowsAbout": ["Exquise", "dental IT", "X-ray systems", "NZa tariffs", "IT support", "Windows", "network"],
    "founder": { "@type": "Person", "name": "Daniel Orosz" }
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Do you work with Exquise?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. I know Exquise from daily practice, not from a manual. Templates, treatment codes, connections with peripherals and the logic around them: I know how it works and where it can go wrong." }
        },
        {
            "@type": "Question",
            "name": "What if my supplier says the problem is not with them?",
            "acceptedAnswer": { "@type": "Answer", "text": "I hear that regularly. IT points to the software, software points to the network, network points to the hardware. I look at the whole picture and find the real cause, without pointing at someone else." }
        },
        {
            "@type": "Question",
            "name": "How quickly do you respond to an outage that stops the practice?",
            "acceptedAnswer": { "@type": "Answer", "text": "For remote support I am usually available within an hour. For on-site help in the Kerkrade–Heerlen area I aim for the same day or next morning. For outages that stop the practice: as fast as possible." }
        },
        {
            "@type": "Question",
            "name": "Do you work only in Kerkrade or broader in Limburg?",
            "acceptedAnswer": { "@type": "Answer", "text": "I work across all of Zuid-Limburg: Heerlen, Kerkrade, Sittard, Maastricht and surrounding areas. Remote support I provide across the Netherlands." }
        },
        {
            "@type": "Question",
            "name": "What does IT support for a small dental practice cost?",
            "acceptedAnswer": { "@type": "Answer", "text": "It depends on the situation. A one-time diagnosis or repair is different from ongoing support. Get in touch for a short intake: I will be straightforward about what is needed and what it costs." }
        }
    ]
};

const services = [
    { title: 'Workstations and network', desc: 'Workstations that hold up, even when Exquise, X-ray software, email and insurance portals all run at once. I make sure the foundation is solid.', icon: 'monitor' },
    { title: 'Exquise and practice software', desc: 'Configuration, templates, treatment codes and the logic around them. I know Exquise from daily practice, not from a manual.', icon: 'app' },
    { title: 'X-ray and medical systems', desc: 'Technical diagnosis when X-ray software or connections fail. I find the cause at the intersection of systems, even when the supplier says it is "not with them".', icon: 'scan' },
    { title: 'Printers and peripherals', desc: 'Small repairs and replacement of printers, scanners and label printers. Without expensive service contracts or long waiting times.', icon: 'printer' },
    { title: 'Internal knowledge base', desc: 'Protocols, codes and procedures made organised and searchable. Answers sit in a system, not in the heads of individual staff.', icon: 'book' },
    { title: 'Onboarding and process support', desc: 'New employees learn the right workflows quickly. Fewer questions, fewer mistakes, less dependency on the one person who knows everything.', icon: 'users' },
    { title: 'NZa tariffs and administrative templates', desc: 'Up to date after every new tariff season. The practice works with current codes, prices and templates.', icon: 'doc' },
    { title: 'Exquise NG migration support', desc: 'Vertimart is moving all practices to Exquise Next Generation: new environment, new settings, new connections, and the risk that templates, codes and peripherals stop working. I guide that transition so the practice does not lose a single day.', icon: 'migrate', highlight: true },
];

const whyReasons = [
    { title: 'Local and reachable', desc: 'Based in Kerkrade, on-site quickly across Zuid-Limburg. No central planning desk, no queue. You call me directly.' },
    { title: 'I know the context', desc: 'Not as an external consultant, but as the person who was in the practice every Monday morning when Exquise locked up, the X-ray connection gave errors or staff did not know what to do next.' },
    { title: 'I fix what falls between systems', desc: 'IT says: the software. Software says: the network. Network says: the hardware. I look at the whole picture and find the real cause, without pointing at someone else.' },
    { title: 'Remote or on-site', desc: 'I fix most problems remotely. Sometimes on-site is faster. You do not need to figure that out, I do.' },
    { title: 'Direct line, no ticket', desc: 'You call me, not a helpdesk number. I know your practice, remember what happened before and do not need everything re-explained every time.' },
];

const faqItems = [
    { question: 'Do you work with Exquise?', answer: 'Yes. I know Exquise from daily practice, not from a manual. Templates, treatment codes, connections with peripherals and the logic around them: I know how it works and where it can go wrong.' },
    { question: 'What if my supplier says the problem is "not with them"?', answer: 'I hear that regularly. IT points to the software, software points to the network, network points to the hardware. I look at the whole picture and find the real cause, without pointing at someone else.' },
    { question: 'How quickly do you respond to an outage that stops the practice?', answer: 'For remote support I am usually available within an hour. For on-site help in the Kerkrade–Heerlen area I aim for the same day or next morning. For outages that stop the practice: as fast as possible.' },
    { question: 'Do you work only in Kerkrade or broader in Limburg?', answer: 'I work across all of Zuid-Limburg: Heerlen, Kerkrade, Sittard, Maastricht and surrounding areas. Remote support I provide across the Netherlands.' },
    { question: 'What does IT support for a small dental practice cost?', answer: 'It depends on the situation. A one-time diagnosis or repair is different from ongoing support. Get in touch for a short intake: I will be straightforward about what is needed and what it costs.' },
];

const iconPaths: Record<string, string> = {
    monitor: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25',
    app: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
    scan: 'M7.5 3.75H6A2.25 2.25 0 003.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0120.25 6v1.5m0 9V18A2.25 2.25 0 0118 20.25h-1.5m-9 0H6A2.25 2.25 0 013.75 18v-1.5M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    printer: 'M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z',
    book: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25',
    users: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
    doc: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
    migrate: 'M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5',
};
---

<Layout title={title} description={description} lang={lang} alternateUrl="/tandarts/">
    <Fragment slot="head">
        <link rel="canonical" href={`${siteUrl}/${slug}/`} />
        <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    </Fragment>

    {/* Breadcrumb */}
    <div class="bg-white border-b border-border">
        <div class="container-main max-w-5xl py-3">
            <nav class="text-sm text-muted-foreground">
                <a href="/en/" class="hover:text-accent transition-colors">Home</a>
                <span class="mx-2 text-border">/</span>
                <span>IT support for dental practices</span>
            </nav>
        </div>
    </div>

    {/* Hero */}
    <section class="relative overflow-hidden bg-white px-4 pt-10 pb-12 sm:px-6 md:pt-12 md:pb-14 lg:px-8">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute -top-32 right-0 h-[500px] w-[500px] rounded-full bg-blue-50 opacity-60 blur-3xl"></div>
            <div class="absolute bottom-0 left-0 h-[300px] w-[400px] rounded-full bg-slate-50 opacity-80 blur-3xl"></div>
        </div>
        <div class="container-main">
            <div class="grid items-center gap-8 lg:grid-cols-[58fr_42fr] lg:gap-10">
                <div class="text-center lg:text-left">
                    <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-semibold text-accent">
                        <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        7 years working daily inside dental practices
                    </div>
                    <h1 class="mb-4 text-[clamp(2rem,5.5vw,3.25rem)] [text-wrap:pretty]">
                        IT support for dental practices<br />
                        <span class="text-accent">that knows the intersection</span>
                    </h1>
                    <p class="mx-auto mb-3 max-w-xl text-base leading-relaxed text-muted-foreground lg:mx-0">
                        For seven years I was the in-house IT specialist at a dental organisation — working inside the practice every day, not as an external vendor. Now I help practices in Zuid-Limburg with workstations, Exquise, X-ray systems and everything in between.
                    </p>
                    <p class="mx-auto mb-6 max-w-xl text-sm font-medium text-foreground lg:mx-0">
                        Fast response · Plain language · No surprises on the invoice<br />
                        <span class="text-muted-foreground font-normal">No call centre. No ticket. You call me directly.</span>
                    </p>
                    <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-start">
                        <a href="#contact" class="btn-primary px-8 py-3.5 text-base">Request Support</a>
                        <a href="#contact" class="btn-outline px-8 py-3.5 text-base">Free Intro Call</a>
                    </div>
                </div>

                <div class="mx-auto flex max-w-sm items-end justify-center lg:mx-0 lg:max-w-none lg:justify-end">
                    <div class="relative">
                        <div class="absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-br from-blue-50 to-slate-50"></div>
                        <img
                            src="/images/daniel-it.png"
                            alt="Daniel Orosz — IT specialist for dental practices"
                            width="597"
                            height="800"
                            class="h-auto w-full max-w-[280px] rounded-2xl object-cover lg:max-w-[340px]"
                            fetchpriority="high"
                            decoding="async"
                        />
                        <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-xl bg-white px-5 py-2.5 text-sm font-semibold text-primary shadow-lg border border-border">
                            Daniel Oros · Kerkrade
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Trust bar */}
    <section class="border-y border-border bg-slate-50 py-4">
        <div class="container-main">
            <ul class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-muted-foreground">
                {[
                    'Based in Kerkrade, active across Zuid-Limburg',
                    '7 years working daily inside dental practices',
                    'Remote help usually available within 60 minutes',
                    'On-site and remote, including acute outages',
                ].map((item) => (
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 shrink-0 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                        {item}
                    </li>
                ))}
            </ul>
        </div>
    </section>

    {/* Services */}
    <section id="services" class="section-padding bg-white">
        <div class="container-main">
            <h2 class="mb-10 text-center">What I do for your practice</h2>
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
                {services.map((s) => (
                    <div class={`group rounded-2xl border p-5 transition-all duration-300 hover:shadow-md ${s.highlight ? 'border-accent bg-blue-50 hover:bg-blue-100/60' : 'border-border bg-white hover:border-accent/30'}`}>
                        <div class={`mb-4 flex h-10 w-10 items-center justify-center rounded-xl ${s.highlight ? 'bg-accent text-white' : 'bg-blue-50 text-accent'}`}>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[s.icon]} />
                            </svg>
                        </div>
                        <h3 class="mb-2 text-base font-semibold">{s.title}</h3>
                        <p class="text-sm leading-relaxed text-muted-foreground">{s.desc}</p>
                        {s.highlight && (
                            <p class="mt-3 text-xs font-semibold text-accent">Is your practice ready for Exquise NG?</p>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </section>

    {/* About Daniel */}
    <section id="about" class="section-padding bg-slate-50">
        <div class="container-main">
            <div class="mx-auto max-w-5xl">
                <div class="grid items-center gap-10 md:grid-cols-5">
                    <div class="flex justify-center md:col-span-2">
                        <div class="relative">
                            <div class="absolute -inset-3 -z-10 rounded-3xl bg-gradient-to-br from-blue-50 to-slate-100"></div>
                            <img
                                src="/images/daniel2_1.png"
                                alt="Daniel Orosz — IT specialist for dental practices"
                                width="597"
                                height="800"
                                class="h-auto w-full max-w-[260px] rounded-2xl object-cover md:max-w-none"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    </div>
                    <div class="md:col-span-3">
                        <h2 class="mb-6">Who is Daniel?</h2>
                        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
                            <p>
                                For seven years I was the only IT person at a dental organisation with multiple locations in the Netherlands. Not as an external vendor, but working inside the practice every day, among the staff, in the middle of the problems. I know the context of a dental practice in a way a generic IT supplier never can.
                            </p>
                            <p>
                                In that period I did not just manage computers and networks. Exquise configuration, X-ray connections, templates, treatment codes, onboarding staff and building the internal knowledge base of the practice: that was my daily work.
                            </p>
                        </div>
                        <div class="mt-6">
                            <p class="font-semibold text-primary">My approach:</p>
                            <p class="text-base text-foreground">Make sure it works, explain what is going on, and no surprises on the bill.</p>
                        </div>
                        <blockquote class="mt-8 border-l-4 border-accent pl-6">
                            <p class="text-lg italic text-primary leading-relaxed">"Quiet IT is the goal. Chaos is what you get when you stop investing in IT that simply works."</p>
                            <footer class="mt-3 text-sm font-semibold text-muted-foreground">— Daniel Orosz</footer>
                        </blockquote>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Why Oros */}
    <section class="section-padding bg-white">
        <div class="container-main">
            <h2 class="mb-10 text-center">Why dental practices choose me</h2>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {whyReasons.map((r, i) => (
                    <div class="rounded-2xl border border-border bg-white p-6 transition-all duration-300 hover:shadow-md hover:border-accent/30">
                        <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg bg-blue-50 text-accent text-sm font-bold">
                            {i + 1}
                        </div>
                        <h3 class="mb-2 text-base font-semibold">{r.title}</h3>
                        <p class="text-sm leading-relaxed text-muted-foreground">{r.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    {/* Uit de praktijk */}
    <section class="section-padding bg-slate-50">
        <div class="container-main max-w-4xl">
            <h2 class="mb-8 text-center">From the practice</h2>
            <div class="grid gap-6 md:grid-cols-2">
                <div class="relative rounded-2xl border border-border bg-white p-6">
                    <div class="absolute -top-3 left-6 flex h-7 w-7 items-center justify-center rounded-full bg-accent text-white text-xs font-bold shadow-sm">1</div>
                    <p class="pt-2 text-sm leading-relaxed text-muted-foreground">
                        An X-ray connection gave weekly error messages. The software supplier said: network problem. The network administrator said: software problem. I analysed both sides at once and found the cause in a conflicting Windows update that hit both systems. Resolved in a day, after three weeks of back-and-forth.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-accent">X-ray system</span>
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-accent">Windows update</span>
                        <span class="rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">Resolved in 1 day</span>
                    </div>
                </div>
                <div class="relative rounded-2xl border border-border bg-white p-6">
                    <div class="absolute -top-3 left-6 flex h-7 w-7 items-center justify-center rounded-full bg-accent text-white text-xs font-bold shadow-sm">2</div>
                    <p class="pt-2 text-sm leading-relaxed text-muted-foreground">
                        A new employee could not work independently in Exquise after a week. No clear workflow, no documentation, everyone explains it differently. I put the logic of the practice into one searchable knowledge base. New employees now onboard in two days instead of two weeks.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-accent">Exquise</span>
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-accent">Knowledge base</span>
                        <span class="rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">2 days vs 2 weeks</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Comparison */}
    <section class="section-padding bg-white">
        <div class="container-main">
            <h2 class="mb-10 text-center">In-house IT vs. IT support for your practice</h2>
            <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
                <div class="rounded-2xl border border-border bg-slate-50 p-6">
                    <h3 class="mb-5 text-center text-base font-bold text-muted-foreground">In-house IT employee</h3>
                    <ul class="space-y-3">
                        {[
                            'Fixed salary + social charges',
                            'Out when sick or on holiday',
                            'Hard to scale for small teams',
                            'No knowledge of Exquise, NZa tariffs or X-ray systems',
                            'Often not cost-effective under 15–20 workstations',
                        ].map((item) => (
                            <li class="flex items-start gap-3 text-sm text-muted-foreground">
                                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>
                <div class="rounded-2xl border-2 border-accent bg-blue-50 p-6">
                    <h3 class="mb-5 text-center text-base font-bold text-accent">Oros IT Support Limburg</h3>
                    <ul class="space-y-3">
                        {[
                            'You only pay for what you use',
                            'Remote + on-site, available when needed',
                            'Direct knowledge of Exquise, X-ray systems and practice processes',
                            'Works for practices of 2 to 30 workstations',
                            'Direct line to Daniel, no queue',
                        ].map((item) => (
                            <li class="flex items-start gap-3 text-sm text-foreground">
                                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
            <p class="mx-auto mt-8 max-w-2xl text-center text-sm text-muted-foreground">
                For most dental practices, flexible IT support is cheaper and more practical than an in-house IT employee who does not know the context of the practice.
            </p>
        </div>
    </section>

    {/* Practice scan */}
    <section class="section-padding bg-slate-50">
        <div class="container-main max-w-3xl">
            <div class="relative overflow-hidden rounded-2xl border border-border bg-gradient-to-br from-slate-50 to-blue-50 p-8">
                <div class="pointer-events-none absolute right-0 top-0 h-40 w-40 -translate-y-8 translate-x-8 rounded-full bg-blue-100 opacity-50 blur-2xl"></div>
                <h2 class="mb-2 text-xl font-bold">Practice scan for dental practices</h2>
                <p class="mb-5 text-muted-foreground">Are you sure the IT in your practice is properly set up?</p>
                <p class="mb-3 text-sm font-semibold text-foreground">I go through:</p>
                <ul class="mb-5 grid gap-1.5 sm:grid-cols-2 text-sm text-muted-foreground">
                    {[
                        'Workstations and computers',
                        'Network and Wi-Fi',
                        'Exquise and peripherals',
                        'X-ray system and connections',
                        'Users, access and backup',
                    ].map((item) => (
                        <li class="flex items-center gap-2">
                            <svg class="h-4 w-4 shrink-0 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                            </svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <p class="mb-6 text-sm text-muted-foreground">
                    You get an overview of what is working well and what needs attention, in plain language, without jargon and without a sales pitch. I send it within two working days.
                </p>
                <a href="#contact" class="btn-primary inline-block px-6 py-3 text-sm">
                    Request a free practice scan — no obligations
                </a>
            </div>
        </div>
    </section>

    {/* Pricing */}
    <section class="section-padding bg-white">
        <div class="container-main max-w-3xl">
            <h2 class="mb-8 text-center">Transparent pricing</h2>
            <div class="overflow-hidden rounded-2xl border border-border bg-white">
                <table class="w-full text-sm border-collapse">
                    <tbody>
                        {[
                            ['Remote support', 'from €65 / hour', 'excl. VAT'],
                            ['On-site support Zuid-Limburg', 'from €79 / hour', 'excl. VAT'],
                            ['Travel costs (local)', 'from €20–30', 'excl. VAT'],
                            ['Practice scan', '€149 – €199', 'excl. VAT'],
                            ['Monthly starter support plan', 'from €149 / month', 'excl. VAT'],
                            ['Per-user monthly package', 'from €35–49 / user / month', 'excl. VAT'],
                        ].map(([label, price, note]) => (
                            <tr class="border-b border-border last:border-0 hover:bg-slate-50 transition-colors">
                                <td class="px-5 py-3.5 font-medium">{label}</td>
                                <td class="px-5 py-3.5 font-semibold text-accent whitespace-nowrap">{price}</td>
                                <td class="px-5 py-3.5 text-muted-foreground text-xs">{note}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            <p class="mt-4 text-center text-xs text-muted-foreground">
                All prices exclude VAT. For larger practices or custom projects I am happy to put together a tailored quote.
            </p>
        </div>
    </section>

    {/* FAQ */}
    <section id="faq" class="section-padding bg-slate-50">
        <div class="container-main max-w-3xl">
            <h2 class="mb-10 text-center">Frequently asked questions from dental practices</h2>
            <div class="space-y-4">
                {faqItems.map((item) => (
                    <details class="group rounded-2xl border border-border bg-white open:shadow-sm transition-all duration-200">
                        <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5 font-semibold text-foreground list-none">
                            <span>{item.question}</span>
                            <svg class="h-5 w-5 shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                            </svg>
                        </summary>
                        <div class="px-6 pb-5 text-sm leading-relaxed text-muted-foreground">
                            {item.answer}
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>

    {/* Final CTA */}
    <section class="section-padding bg-primary text-white">
        <div class="container-main max-w-2xl text-center">
            <h2 class="mb-4 text-white">Ready to get the IT in your practice sorted?</h2>
            <p class="mb-8 text-white/75">
                No sales talk. No obligations. Just a short conversation to see if I can help your practice. I have limited capacity for new practices in Limburg, so get in touch if you are interested.
            </p>
            <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
                <a href="#contact" class="btn-primary px-8 py-3.5 text-base bg-white text-primary hover:bg-white/90">Request Support</a>
                <a href="#contact" class="px-8 py-3.5 text-base rounded-xl border border-white/30 text-white hover:bg-white/10 transition-colors">Free Intro Call</a>
            </div>
        </div>
    </section>

    <ContactForm lang={lang} />
</Layout>
