---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm';

const lang = 'en';
const slug = 'boekhouder';
const siteUrl = 'https://ict-support-limburg.nl';

const title = 'IT support for accounting and bookkeeping firms in Limburg | Oros IT Support';
const description = 'IT support for accounting and bookkeeping firms in South Limburg. Exact Online, Twinfield, Yuki, Peppol. Fast, local, no generic helpdesk. Familiar with the daily office workflow.';

const localBusinessSchema = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Oros IT Support Limburg",
    "description": description,
    "url": `${siteUrl}/en/${slug}/`,
    "telephone": "+31634836118",
    "email": "daniel@ict-support-limburg.nl",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "Kievitstraat 25",
        "addressLocality": "Kerkrade",
        "addressRegion": "Limburg",
        "postalCode": "6469 XX",
        "addressCountry": "NL"
    },
    "areaServed": [
        { "@type": "City", "name": "Kerkrade" },
        { "@type": "City", "name": "Heerlen" },
        { "@type": "City", "name": "Maastricht" },
        { "@type": "City", "name": "Sittard" }
    ],
    "knowsAbout": ["Exact Online", "Twinfield", "Yuki", "Peppol", "e-invoicing", "Microsoft 365", "GDPR", "accounting firm IT", "bookkeeping office ICT"],
    "founder": { "@type": "Person", "name": "Daniel Orosz" }
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Do you work with Exact Online, Twinfield or Yuki?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. I know these systems from daily office work, not from a manual. Integrations, synchronisations, user settings and the logic around them." }
        },
        {
            "@type": "Question",
            "name": "What if my software vendor says the problem is not with them?",
            "acceptedAnswer": { "@type": "Answer", "text": "I hear that regularly. IT points to the software, software points to the network, network points to the hardware. I look at the whole picture and find the actual cause." }
        },
        {
            "@type": "Question",
            "name": "What is Peppol and do I need to do something about it now?",
            "acceptedAnswer": { "@type": "Answer", "text": "Peppol is the standard for electronic invoicing becoming mandatory across Europe. For accounting and bookkeeping firms this matters twice: for your own invoices and for your clients'. I help set this up practically." }
        },
        {
            "@type": "Question",
            "name": "How quickly do you respond when a problem is stopping the office?",
            "acceptedAnswer": { "@type": "Answer", "text": "For remote support I am usually available within an hour. For on-site in the Kerkrade–Heerlen area I aim for same day or next morning." }
        },
        {
            "@type": "Question",
            "name": "Do you work alongside an existing IT provider?",
            "acceptedAnswer": { "@type": "Answer", "text": "I don't replace anyone. I handle what falls between the cracks: the office-specific things a generic MSP doesn't know or doesn't want to deal with." }
        }
    ]
};

const services = [
    { title: 'Access management and Microsoft 365', desc: 'New employee, departing colleague, changed role: I make sure the right people have access and the wrong people no longer do. MFA, shared mailboxes, licences.', icon: 'users' },
    { title: 'System integrations', desc: 'Exact Online, Twinfield or Yuki not playing well with your client portal, DMS or payroll module? I find the actual cause, even when vendors point at each other.', icon: 'link' },
    { title: 'Backup and recovery', desc: 'A backup that has never been tested is not a backup. I check not only whether a backup exists, but whether you can actually restore from it.', icon: 'shield' },
    { title: 'Peppol and e-invoicing', desc: 'The European e-invoicing mandate is coming. I help your firm and your clients set this up properly, without bringing the process to a halt.', icon: 'doc' },
    { title: 'Onboarding and knowledge base', desc: 'New staff learn the right workflows quickly. Procedures and processes made searchable and organised, so knowledge does not sit in one person\'s head.', icon: 'book' },
    { title: 'AI tools — safe use', desc: 'ChatGPT and similar tools offer real opportunities for office processes, but also carry risks. I help you use them without client data ending up on personal accounts.', icon: 'sparkle' },
    { title: 'Printers, scanners and peripherals', desc: 'Small repairs and replacements without expensive service contracts or long wait times.', icon: 'printer' },
    { title: 'Vendor coordination', desc: 'IT says: software. Software says: network. Network says: hardware. I look at the whole picture and find the actual cause, not who to blame.', icon: 'arrows' },
];

const whyReasons = [
    { title: 'I understand the office logic', desc: 'My mother was a bookkeeper. I grew up with the logic of administration: precise work, attention to detail, zero tolerance for mistakes that cost money. That gives a different perspective than a generic IT provider.' },
    { title: 'Familiar with Exact, Twinfield and Yuki', desc: 'Not from a manual — from daily office work. Integrations, synchronisations, user settings and the logic around them: I know how they work and where they go wrong.' },
    { title: 'Local and reachable', desc: 'Based in Kerkrade, on-site quickly across South Limburg. No central scheduling service, no queue. You call me directly.' },
    { title: 'GDPR as standard', desc: 'Firms work with client files. I factor that in with every action: access, storage, cloud apps and offboarding. Not a policy I look up — it\'s how I work by default.' },
    { title: 'Direct line, no ticket', desc: 'You call me, not a helpdesk number. I know your firm, I know what happened before, and I don\'t need the context explained to me every time.' },
];

const faqItems = [
    { question: 'Do you work with Exact Online, Twinfield or Yuki?', answer: 'Yes. I know these systems from daily office work, not from a manual. Integrations, synchronisations, user settings and the logic around them.' },
    { question: 'What if my software vendor says the problem is not with them?', answer: 'I hear that regularly. IT points to the software, software points to the network, network points to the hardware. I look at the whole picture and find the actual cause.' },
    { question: 'What is Peppol and do I need to do something about it now?', answer: 'Peppol is the standard for electronic invoicing becoming mandatory across Europe. For accounting and bookkeeping firms this matters twice: for your own invoices and for your clients\'. I help set this up practically.' },
    { question: 'How quickly do you respond when a problem is stopping the office?', answer: 'For remote support I am usually available within an hour. For on-site in the Kerkrade–Heerlen area I aim for same day or next morning.' },
    { question: 'Do you work alongside an existing IT provider?', answer: 'I don\'t replace anyone. I handle what falls between the cracks: the office-specific things a generic MSP doesn\'t know or doesn\'t want to deal with.' },
];

const iconPaths: Record<string, string> = {
    users: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
    link: 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
    shield: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
    doc: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
    book: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0118 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25',
    sparkle: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z',
    printer: 'M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z',
    arrows: 'M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5',
};
---

<Layout title={title} description={description} lang={lang} alternateUrl="/boekhouder/">
    <Fragment slot="head">
        <link rel="canonical" href={`${siteUrl}/en/${slug}/`} />
        <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    </Fragment>

    {/* Breadcrumb */}
    <div class="bg-white border-b border-border">
        <div class="container-main max-w-5xl py-3">
            <nav class="text-sm text-muted-foreground">
                <a href="/en/" class="hover:text-accent transition-colors">Home</a>
                <span class="mx-2 text-border">/</span>
                <span>IT for accounting and bookkeeping firms</span>
            </nav>
        </div>
    </div>

    {/* Hero */}
    <section class="relative overflow-hidden bg-white section-padding !pb-14 md:!pb-16">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute -top-32 right-0 h-[500px] w-[500px] rounded-full bg-blue-50 opacity-60 blur-3xl"></div>
            <div class="absolute bottom-0 left-0 h-[300px] w-[400px] rounded-full bg-slate-50 opacity-80 blur-3xl"></div>
        </div>
        <div class="container-main">
            <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-12">
                <div class="text-center lg:text-left">
                    <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-semibold text-accent">
                        <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Familiar with the daily workflow of accounting and bookkeeping firms
                    </div>
                    <h1 class="mb-5">
                        IT support for accounting and bookkeeping firms<br />
                        <span class="text-accent">that understands your office logic</span>
                    </h1>
                    <p class="mx-auto mb-4 max-w-2xl text-lg leading-relaxed text-muted-foreground lg:mx-0">
                        For years I worked alongside accounting departments, handling invoices, tax returns and administrative workflows. Now I help firms in South Limburg with the IT that keeps the daily workflow running.
                    </p>
                    <p class="mx-auto mb-8 max-w-xl text-base font-medium text-foreground lg:mx-0">
                        Fast help · Clear explanations · No surprises on the invoice<br />
                        <span class="text-muted-foreground font-normal">No call centre. No ticket system. You call me directly.</span>
                    </p>
                    <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-start">
                        <a href="#contact" class="btn-primary px-8 py-3.5 text-base">Request support</a>
                        <a href="https://calendly.com/daniilos123/30min" target="_blank" rel="noopener" class="btn-outline px-8 py-3.5 text-base">Schedule a call</a>
                    </div>
                </div>

                <div class="mx-auto flex max-w-sm items-end justify-center lg:mx-0 lg:max-w-none lg:justify-end">
                    <div class="relative">
                        <div class="absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-br from-blue-50 to-slate-50"></div>
                        <img
                            src="/images/daniel-it.png"
                            alt="Daniel Orosz — IT specialist for accounting and bookkeeping firms"
                            width="597"
                            height="800"
                            class="h-auto w-full max-w-[320px] rounded-2xl object-cover lg:max-w-[380px]"
                            fetchpriority="high"
                            decoding="async"
                        />
                        <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-xl bg-white px-5 py-2.5 text-sm font-semibold text-primary shadow-lg border border-border">
                            Daniel Oros · Kerkrade
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Trust bar */}
    <section class="border-y border-border bg-slate-50 py-4">
        <div class="container-main">
            <ul class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-muted-foreground">
                {[
                    'Based in Kerkrade, active across South Limburg',
                    'Familiar with Exact Online, Twinfield, Yuki and Microsoft 365',
                    'Remote support usually available within 60 minutes',
                    'Privacy-aware: GDPR workflow for firms handling client files',
                ].map((item) => (
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 shrink-0 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                        {item}
                    </li>
                ))}
            </ul>
        </div>
    </section>

    {/* Services */}
    <section id="services" class="section-padding bg-white">
        <div class="container-main">
            <div class="mb-10 text-center">
                <h2>What I do for your firm</h2>
            </div>
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
                {services.map((s) => (
                    <div class="group rounded-2xl border border-border bg-white p-5 transition-all duration-300 hover:shadow-md hover:border-accent/30">
                        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-accent">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[s.icon]} />
                            </svg>
                        </div>
                        <h3 class="mb-2 text-base font-semibold">{s.title}</h3>
                        <p class="text-sm leading-relaxed text-muted-foreground">{s.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    {/* About Daniel */}
    <section id="about" class="section-padding bg-slate-50">
        <div class="container-main">
            <div class="mx-auto max-w-5xl">
                <div class="grid items-center gap-10 md:grid-cols-5">
                    <div class="flex justify-center md:col-span-2">
                        <div class="relative">
                            <div class="absolute -inset-3 -z-10 rounded-3xl bg-gradient-to-br from-blue-50 to-slate-100"></div>
                            <img
                                src="/images/daniel2_1.png"
                                alt="Daniel Orosz — IT specialist for accounting and bookkeeping firms"
                                width="597"
                                height="800"
                                class="h-auto w-full max-w-[260px] rounded-2xl object-cover md:max-w-none"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    </div>
                    <div class="md:col-span-3">
                        <h2 class="mb-6">Who is Daniel?</h2>
                        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
                            <p>
                                My mother was a bookkeeper. I grew up with the logic of administration: precise work, attention to detail, zero tolerance for mistakes that cost money.
                            </p>
                            <p>
                                On the technical side, I managed the IT environment of an organisation for years — including the accounting department. Invoice workflows, stock management, access to administrative systems, and everything in between. I know how a firm thinks.
                            </p>
                            <p>
                                That makes me different from a generic IT provider who has never worked in your world.
                            </p>
                        </div>
                        <div class="mt-6">
                            <p class="font-semibold text-primary">My approach:</p>
                            <p class="text-base text-foreground">Make it work, explain what happened, no fuss about the invoice.</p>
                        </div>
                        <blockquote class="mt-8 border-l-4 border-accent pl-6">
                            <p class="text-lg italic text-primary leading-relaxed">"Silent IT is the goal. Every hour a staff member spends on an IT problem is an hour that can't be billed."</p>
                            <footer class="mt-3 text-sm font-semibold text-muted-foreground">— Daniel Orosz</footer>
                        </blockquote>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Why Oros */}
    <section class="section-padding bg-white">
        <div class="container-main">
            <h2 class="mb-10 text-center">Why accounting firms choose me</h2>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {whyReasons.map((r, i) => (
                    <div class="rounded-2xl border border-border bg-white p-6 transition-all duration-300 hover:shadow-md hover:border-accent/30">
                        <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg bg-blue-50 text-accent text-sm font-bold">
                            {i + 1}
                        </div>
                        <h3 class="mb-2 text-base font-semibold">{r.title}</h3>
                        <p class="text-sm leading-relaxed text-muted-foreground">{r.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    {/* Common problems */}
    <section class="section-padding bg-slate-50">
        <div class="container-main max-w-4xl">
            <h2 class="mb-8 text-center">What I help with daily in accounting firms</h2>
            <div class="grid gap-3 sm:grid-cols-2">
                {[
                    'New staff access not working on day one',
                    'Exact Online, Twinfield or Yuki synchronisation errors',
                    'Client portal or DMS integration broken after an update',
                    'Backup exists, but restore has never been tested',
                    'Departing employee still has access',
                    'Peppol or e-invoicing not yet set up',
                    'AI tools already in use but without policy or security',
                    'Reception printer or scanner not working',
                ].map((p) => (
                    <div class="flex items-start gap-3 rounded-xl border border-border bg-white px-4 py-3.5 transition-colors hover:border-accent/30">
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-sm text-foreground">{p}</span>
                    </div>
                ))}
            </div>
        </div>
    </section>

    {/* Uit de praktijk */}
    <section class="section-padding bg-white">
        <div class="container-main max-w-4xl">
            <h2 class="mb-8 text-center">From practice</h2>
            <div class="grid gap-6 md:grid-cols-2">
                <div class="relative rounded-2xl border border-border bg-slate-50 p-6">
                    <div class="absolute -top-3 left-6 flex h-7 w-7 items-center justify-center rounded-full bg-accent text-white text-xs font-bold shadow-sm">1</div>
                    <p class="pt-2 text-sm leading-relaxed text-muted-foreground">
                        An integration between Exact Online and a client portal was throwing errors every week. The software vendor pointed to the network. The network provider pointed to the software. I analysed both sides at the same time and found a conflicting update as the cause. Fixed in one day, after two weeks of back-and-forth.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-accent">Exact Online</span>
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-accent">Integration</span>
                        <span class="rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">Fixed in 1 day</span>
                    </div>
                </div>
                <div class="relative rounded-2xl border border-border bg-slate-50 p-6">
                    <div class="absolute -top-3 left-6 flex h-7 w-7 items-center justify-center rounded-full bg-accent text-white text-xs font-bold shadow-sm">2</div>
                    <p class="pt-2 text-sm leading-relaxed text-muted-foreground">
                        A newly hired employee still could not work independently after four days. No clear workflow, no documentation, everyone explained it differently. I turned the office logic into one searchable knowledge base. New staff now onboard in two days instead of two weeks.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-accent">Onboarding</span>
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-accent">Knowledge base</span>
                        <span class="rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">2 days instead of 2 weeks</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Comparison */}
    <section class="section-padding bg-slate-50">
        <div class="container-main">
            <h2 class="mb-10 text-center">In-house IT vs. IT support for your firm</h2>
            <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
                <div class="rounded-2xl border border-border bg-white p-6">
                    <h3 class="mb-5 text-center text-base font-bold text-muted-foreground">In-house IT employee</h3>
                    <ul class="space-y-3">
                        {[
                            'Fixed salary + employment costs',
                            'Unavailable when sick or on holiday',
                            'Rarely knows Exact, Twinfield or Yuki',
                            'GDPR awareness depends on the individual',
                            'Often not cost-effective below 15–20 workstations',
                        ].map((item) => (
                            <li class="flex items-start gap-3 text-sm text-muted-foreground">
                                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span>{item}</span>
                            </li>
                        ))}
